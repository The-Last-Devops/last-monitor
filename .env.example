# Hub
CONFIG_DATABASE_URL=postgres://lastmon:lastmon@localhost:5432/lastmon_config
DATA_DATABASE_URL=postgres://lastmon:lastmon@localhost:5432/lastmon_data
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,sqlx=warn

# First admin (bootstrapped on startup)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me

# Bundled compose agent: hub seeds a "local" server with this token,
# and the agent service authenticates with the same value.
LOCAL_AGENT_TOKEN=local-dev-token
AGENT_INTERVAL=10

# Standalone agent (running on another host)
HUB_URL=http://localhost:8080
AGENT_TOKEN=replace-with-token-from-hub
INTERVAL=15
