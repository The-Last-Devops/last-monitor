# syntax=docker/dockerfile:1
# Tiny agent image. cargo-chef caches the dependency layer so code-only pushes
# don't recompile the whole dependency tree (the slow part, esp. under arm64).
FROM rust:1-bookworm AS chef
RUN cargo install cargo-chef --locked
WORKDIR /app

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS build
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release -p agent --recipe-path recipe.json
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo build --release -p agent && cp target/release/last-agent /usr/local/bin/last-agent

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /usr/local/bin/last-agent /usr/local/bin/last-agent
ENTRYPOINT ["last-agent"]
